# ==============================================================================
# EduDrive — Environment Variables Template
# ==============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
# ==============================================================================

# --- General ---
NODE_ENV=development
PORT=3001

# --- PostgreSQL ---
DATABASE_URL=postgresql://edudrive:edudrive_dev_password@localhost:5432/edudrive

# --- JWT ---
JWT_ACCESS_SECRET=change_me_to_a_random_string_at_least_32_chars
JWT_REFRESH_SECRET=change_me_to_another_random_string_at_least_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- S3-Compatible Storage (MinIO for dev, R2/B2 for prod) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY=edudrive_access_key
S3_SECRET_KEY=edudrive_secret_key
S3_BUCKET=edudrive-files
# Set to true for MinIO/local dev, false for AWS/R2
S3_FORCE_PATH_STYLE=true

# --- Frontend ---
FRONTEND_URL=http://localhost:5173

# --- Upload Limits ---
MAX_FILE_SIZE_MB=50

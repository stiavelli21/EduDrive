    "express": "^4.21.0",
    "google-auth-library": "^10.9.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "multer": "^2.2.0",
    "pg": "^8.13.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",

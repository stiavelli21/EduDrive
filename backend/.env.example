# Backend-specific env (copy to .env)
# See root .env.example for full documentation

# --- 1. DATABASE POSTGRESQL ---
# Opzione A (Locale con Docker Compose):
DATABASE_URL=postgresql://edudrive:edudrive_dev_password@localhost:5432/edudrive
# Opzione B (Cloud Gratis con Neon.tech - scommenta e inserisci il tuo URL con ?sslmode=require):
# DATABASE_URL=postgresql://user:password@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
# DB_SSL=true

# --- 2. AUTENTICAZIONE (JWT) ---
JWT_ACCESS_SECRET=dev_access_secret_change_in_production_32chars
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_production_32chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- 3. STORAGE S3 COMPATIBILE ---
# Opzione A (Locale con MinIO Docker):
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY=edudrive_access_key
S3_SECRET_KEY=edudrive_secret_key
S3_BUCKET=edudrive-files
S3_FORCE_PATH_STYLE=true

# Opzione B (Cloud Gratis con Storj.io / Supabase / Cloudflare R2):
# S3_ENDPOINT=https://gateway.storjshare.io
# S3_ACCESS_KEY=tua_access_key_storj
# S3_SECRET_KEY=tua_secret_key_storj
# S3_BUCKET=edudrive-files
# S3_FORCE_PATH_STYLE=true

# --- 4. SERVER & FRONTEND ---
FRONTEND_URL=http://localhost:5173
PORT=3001
MAX_FILE_SIZE_MB=50

# --- 5. GOOGLE / FIREBASE AUTHENTICATION (Facoltativo - per verifica ID Token) ---
# GOOGLE_CLIENT_ID=123456789-abcdef.apps.googleusercontent.com
# FIREBASE_PROJECT_ID=your-firebase-project-id


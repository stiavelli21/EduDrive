# Backend-specific env (copy to .env)
# See root .env.example for full documentation

DATABASE_URL=postgresql://edudrive:edudrive_dev_password@localhost:5432/edudrive

JWT_ACCESS_SECRET=dev_access_secret_change_in_production_32chars
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_production_32chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY=edudrive_access_key
S3_SECRET_KEY=edudrive_secret_key
S3_BUCKET=edudrive-files
S3_FORCE_PATH_STYLE=true

FRONTEND_URL=http://localhost:5173
PORT=3001
MAX_FILE_SIZE_MB=50

# Frontend Environment Variables
# Per lo sviluppo locale con Docker, puoi lasciare vuoto (Vite utilizzerà il proxy automatico verso localhost:3001).
# Quando fai il deploy o colleghi il frontend a Render.com in Cloud, inserisci l'URL del backend con "/api" finale:

# VITE_API_URL=http://localhost:3001/api

# Configurazione Firebase Auth (per pulsante "Accedi con Google" — Gratis su Firebase Console)
# VITE_FIREBASE_API_KEY=AIzaSy...
# VITE_FIREBASE_AUTH_DOMAIN=edudrive.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=edudrive
# VITE_FIREBASE_STORAGE_BUCKET=edudrive.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
# VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef
